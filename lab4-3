using System;

namespace Lab3
{
    class Program
    {
        public static int GetElementCount(int[] items, int itemToCount)
        {
            return items.Count(i => i == itemToCount);
        }

        public static void Main()
        {
            int[] array = new int[] { 1, 3, 3 };
            var str = string.Join(" ", array);
            Console.WriteLine($"Элементы массива: " + str);
            Console.WriteLine($"Элемент повторяется: " + GetElementCount(array, 3));
        }
    }
}
